<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <!--// PackageView template //-->
  <template class="PackageView" parent="AdwBin">
    <child>
      <object class="AdwToolbarView" id="toolbar_view">
        <property name="top-bar-style">raised</property>
        <property name="bottom-bar-style">raised</property>
        <child type="top">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <object class="AdwHeaderBar" id="header_bar">
                <property name="title-widget">
                  <object class="AdwWindowTitle">
                    <property name="title">Packages</property>
                  </object>
                </property>
                <child>
                  <object class="GtkButton" id="sidebar_button">
                    <property name="visible">false</property>
                    <property name="icon-name">sidebar-show-symbolic</property>
                    <property name="tooltip-text">Show Sidebar</property>
                    <property name="action-name">win.show-sidebar</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="search_button">
                    <property name="active">false</property>
                    <property name="icon-name">edit-find-symbolic</property>
                    <property name="tooltip-text">Toggle Search</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkMenuButton" id="main_menu_button">
                    <property name="visible">false</property>
                    <property name="icon-name">open-menu-symbolic</property>
                    <property name="primary">true</property>
                    <property name="tooltip-text">Main Menu</property>
                    <property name="menu-model">primary_menu</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton" id="infopane_button">
                    <property name="visible">false</property>
                    <property name="icon-name">sidebar-show-right-symbolic</property>
                    <property name="tooltip-text">Show Info Pane</property>
                    <property name="action-name">win.show-infopane</property>
                  </object>
                </child>
                <child type="end">
                  <object class="AdwSplitButton" id="sort_button">
                    <property name="icon-name">view-sort-ascending-symbolic</property>
                    <property name="menu-model">sort_menu</property>
                    <property name="tooltip-text">Sort Descending</property>
                    <property name="dropdown-tooltip">Sort Options</property>
                    <property name="action-name">view.set-sort-ascending</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkToggleButton" id="grouping_button">
                    <property name="icon-name">repository-symbolic</property>
                    <property name="tooltip-text">Group by Repository</property>
                    <property name="action-name">view.set-grouping</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="SearchBar" id="search_bar"/>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkStack" id="stack">
            <property name="vexpand">true</property>
            <child>
              <object class="GtkStackPage">
                <property name="name">view</property>
                <property name="child">
                  <object class="GtkOverlay">
                    <property name="child">
                      <object class="GtkScrolledWindow">
                        <property name="hexpand">true</property>
                        <property name="vexpand">true</property>
                        <child>
                          <object class="GtkListView" id="view">
                            <property name="tab-behavior">item</property>
                            <property name="model">
                              <object class="GtkSingleSelection" id="selection">
                                <property name="model">
                                  <object class="GtkSortListModel" id="sort_model">
                                    <property name="model">
                                      <object class="GtkFilterListModel" id="filter_model">
                                        <property name="filter">
                                          <object class="GtkEveryFilter" id="main_filter">
                                            <child>
                                              <object class="GtkStringFilter" id="repo_filter">
                                                <property name="expression">
                                                  <lookup name="repository" type="PkgObject"/>
                                                </property>
                                                <property name="match-mode">exact</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkCustomFilter" id="status_filter"/>
                                            </child>
                                            <child>
                                              <object class="GtkCustomFilter" id="search_filter"/>
                                            </child>
                                          </object>
                                        </property>
                                        <property name="model">
                                          <object class="GtkFlattenListModel" id="flatten_model">
                                            <property name="model">
                                              <object class="GListStore">
                                                <child>
                                                  <object class="GListStore" id="pkg_model">
                                                    <property name="item-type">PkgObject</property>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GListStore" id="aur_model">
                                                    <property name="item-type">PkgObject</property>
                                                  </object>
                                                </child>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                      </object>
                                    </property>
                                    <property name="sorter">
                                      <object class="GtkCustomSorter" id="sorter"/>
                                    </property>
                                    <property name="section-sorter">
                                      <object class="GtkStringSorter" id="section_sorter">
                                        <property name="expression">
                                          <lookup name="repository" type="PkgObject"/>
                                        </property>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </property>
                            <property name="factory">
                              <object class="GtkSignalListItemFactory" id="factory"/>
                            </property>
                            <property name="header-factory">
                              <object class="GtkBuilderListItemFactory" id="header_factory">
                                <property name="resource">/com/github/PacView/ui/package_view/header.ui</property>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </property>
                    <child type="overlay">
                      <object class="AdwStatusPage" id="empty_status">
                        <property name="icon-name">edit-find-symbolic</property>
                        <property name="title">No Packages Found</property>
                        <style>
                          <class name="compact"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">spinner</property>
                <property name="child">
                  <object class="AdwStatusPage" id="loading_status">
                    <property name="title"></property>
                    <property name="paintable">
                      <object class="AdwSpinnerPaintable">
                        <property name="widget">loading_status</property>
                      </object>
                    </property>
                    <style>
                      <class name="compact"/>
                    </style>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </property>
        <child type="bottom">
          <object class="GtkLabel" id="count_label">
            <property name="margin-top">8</property>
            <property name="margin-bottom">8</property>
            <style>
              <class name="heading"/>
              <class name="dimmed"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </template>

  <!--// Primary menu //-->
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label">Refresh</attribute>
        <attribute name="action">win.refresh</attribute>
      </item>
      <item>
        <attribute name="label">Check for Updates</attribute>
        <attribute name="action">win.check-updates</attribute>
      </item>
      <item>
        <attribute name="label">Update AUR Database</attribute>
        <attribute name="action">win.update-aur-database</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Copy Package List</attribute>
        <attribute name="action">win.copy-package-list</attribute>
      </item>
    </section>
    <section>
      <submenu>
        <attribute name="label">View</attribute>
        <item>
          <attribute name="label">Statistics</attribute>
          <attribute name="action">win.show-stats</attribute>
        </item>
        <item>
          <attribute name="label">Backup Files</attribute>
          <attribute name="action">win.show-backup-files</attribute>
        </item>
        <item>
          <attribute name="label">Pacman Log</attribute>
          <attribute name="action">win.show-pacman-log</attribute>
        </item>
        <item>
          <attribute name="label">Pacman Cache</attribute>
          <attribute name="action">win.show-pacman-cache</attribute>
        </item>
        <item>
          <attribute name="label">Pacman Groups</attribute>
          <attribute name="action">win.show-pacman-groups</attribute>
        </item>
        <item>
          <attribute name="label">Pacman Config</attribute>
          <attribute name="action">win.show-pacman-config</attribute>
        </item>
      </submenu>
    </section>
    <section>
      <item>
        <attribute name="label">Preferences</attribute>
        <attribute name="action">win.show-preferences</attribute>
      </item>
      <item>
        <attribute name="label">Keyboard Shortcuts</attribute>
        <attribute name="action">app.shortcuts</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">About PacView</attribute>
        <attribute name="action">app.show-about</attribute>
      </item>
    </section>
  </menu>

  <!--// Package sort menu //-->
  <menu id="sort_menu">
    <section>
      <attribute name="label">Sort Property</attribute>
      <item>
        <attribute name="label">Name</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">name</attribute>
      </item>
      <item>
        <attribute name="label">Repository</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">repository</attribute>
      </item>
      <item>
        <attribute name="label">Status</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">status</attribute>
      </item>
      <item>
        <attribute name="label">Install Date</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">install-date</attribute>
      </item>
      <item>
        <attribute name="label">Installed Size</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">installed-size</attribute>
      </item>
      <item>
        <attribute name="label">Groups</attribute>
        <attribute name="action">view.set-sort-prop</attribute>
        <attribute name="target">groups</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Reset Sorting</attribute>
        <attribute name="action">view.reset-sort</attribute>
      </item>
    </section>
  </menu>
</interface>
