<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <!--// InfoPane template //-->
  <template class="InfoPane" parent="AdwBin">
    <property name="child">
      <object class="GtkStack" id="main_stack">
        <child>
          <object class="GtkStackPage">
            <property name="name">empty</property>
            <property name="child">
              <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="title-widget">
                      <object class="AdwWindowTitle">
                        <property name="title"></property>
                      </object>
                    </property>
                  </object>
                </child>
                <property name="content">
                  <object class="AdwStatusPage" id="empty_status">
                    <property name="icon-name">package-x-generic-symbolic</property>
                    <property name="title">No Package Selected</property>
                    <style>
                      <class name="compact"/>
                    </style>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkStackPage">
            <property name="name">properties</property>
            <property name="child">
              <object class="AdwToolbarView" id="toolbar_view">
                <child type="top">
                  <object class="AdwHeaderBar" id="header_bar">
                    <property name="title-widget">
                      <object class="AdwInlineViewSwitcher" id="tab_switcher">
                        <property name="hexpand">true</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="stack">tab_stack</property>
                        <property name="display-mode">labels</property>
                        <property name="homogeneous">true</property>
                      </object>
                    </property>
                    <child>
                      <object class="GtkButton" id="prev_button">
                        <property name="sensitive">false</property>
                        <property name="icon-name">go-previous-symbolic</property>
                        <property name="tooltip-text">Previous</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="next_button">
                        <property name="sensitive">false</property>
                        <property name="icon-name">go-next-symbolic</property>
                        <property name="tooltip-text">Next</property>
                      </object>
                    </child>
                  </object>
                </child>
                <property name="content">
                  <object class="AdwViewStack" id="tab_stack">
                    <property name="margin-top">20</property>
                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">info</property>
                        <property name="title">Info</property>
                        <property name="child">
                          <object class="InfoDetailsTab" id="info_tab"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">files</property>
                        <property name="title">Files</property>
                        <property name="child">
                          <object class="InfoFilesTab" id="files_tab"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwViewStackPage">
                        <property name="name">log</property>
                        <property name="title">Log</property>
                        <property name="child">
                          <object class="InfoLogTab" id="log_tab"/>
                        </property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
