<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <!--// StatusItemIndicator template //-->
  <template class="StatusItemIndicator" parent="GtkBox">
    <style>
      <class name="status-row-indicator"/>
    </style>
    <property name="valign">center</property>
    <property name="spacing">6</property>
    <child>
      <object class="GtkMenuButton" id="error_button">
        <property name="visible">false</property>
        <property name="icon-name">info-outline-symbolic</property>
        <property name="popover">error_popover</property>
        <style>
          <class name="circular"/>
          <class name="flat"/>
          <class name="error"/>
        </style>
      </object>
    </child>
    <child>
      <object class="AdwSpinner" id="spinner">
        <property name="visible">false</property>
        <style>
          <class name="accent"/>
        </style>
      </object>
    </child>
    <child>
      <object class="GtkLabel" id="count_label">
        <property name="visible">false</property>
        <style>
          <class name="caption-heading"/>
          <class name="numeric"/>
        </style>
      </object>
    </child>
  </template>

  <!--// Error popover //-->
  <object class="GtkPopover" id="error_popover">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-top">6</property>
        <property name="margin-bottom">8</property>
        <property name="spacing">4</property>
        <child>
          <object class="GtkLabel">
            <property name="label">Update Error</property>
            <property name="xalign">0</property>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="error_label">
            <property name="xalign">0</property>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
